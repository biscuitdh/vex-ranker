{% extends "gui_base.html.j2" %}
{% import "gui_primitives.html.j2" as ui %}
{% set page_title = "Matches" %}
{% block content %}
  {% set team_label = selected_team_number or (latest_snapshot.team_number if latest_snapshot else settings.team_number) %}
  {% call ui.page_intro("Matches", team_label ~ " Match Slate", "Track what already happened and what is queued next for the selected team.") %}
    <a class="header-action" href="{{ ('/' ~ team_query) if not static_site and team_query else ('/' if not static_site else '../index.html' ~ team_query) }}">Back To Dashboard</a>
    {% if static_site %}
      <a class="header-action" href="../ai-rankings/{{ team_query }}">Open AI Rankings</a>
    {% endif %}
  {% endcall %}

  {% if static_site %}
  {{ ui.metric_grid([
    {"label": "Next Match", "value": match_intelligence.next_match.round_label if match_intelligence and match_intelligence.next_match else "Unknown"},
    {"label": "Next Time", "value": display_time(match_intelligence.next_match.scheduled_time) if match_intelligence and match_intelligence.next_match and match_intelligence.next_match.scheduled_time else "TBD"},
    {"label": "Next Field", "value": match_intelligence.next_match.field_name if match_intelligence and match_intelligence.next_match and match_intelligence.next_match.field_name else "TBD"},
    {"label": "Last Result", "value": ((match_intelligence.last_match.score_for|string) ~ "-" ~ (match_intelligence.last_match.score_against|string)) if match_intelligence and match_intelligence.last_match and match_intelligence.last_match.score_for is not none and match_intelligence.last_match.score_against is not none else "Unknown"},
  ]) }}
  <div class="page-note small">Updated {{ display_time(export_metadata.generated_at) }} · Next slate from {{ display_source_name((match_intelligence.next_match.source if match_intelligence and match_intelligence.next_match else latest_snapshot.source if latest_snapshot else 'unknown')) }}</div>
  {% endif %}

  <div class="split">
    <section class="summary-card">
      {{ ui.section_header("Scout", "Next Match Intelligence", "The next known match with opponent context from official and derived ranking tables.") }}
      {% if match_intelligence.next_match %}
        <table>
          <tbody>
            <tr><th>Match</th><td>{{ match_intelligence.next_match.round_label or match_intelligence.next_match.match_key }}</td></tr>
            <tr><th>Opponents</th><td>{{ ", ".join(match_intelligence.next_match.opponent_teams) if match_intelligence.next_match.opponent_teams else match_intelligence.next_match.opponent or "TBD" }}</td></tr>
            <tr><th>Scheduled</th><td>{{ display_time(match_intelligence.next_match.scheduled_time) if static_site and match_intelligence.next_match.scheduled_time else match_intelligence.next_match.scheduled_time or "TBD" }}</td></tr>
            <tr><th>Location</th><td>{{ match_intelligence.next_match.field_name or "TBD" }}</td></tr>
            {% if not static_site %}
              {% set next_source_class = "source-" ~ (match_intelligence.next_match.source or "unknown")|replace("_", "-") %}
              <tr><th>Source</th><td><span class="badge {{ next_source_class }}">{{ (match_intelligence.next_match.source or "unknown")|replace("_", " ") }}</span></td></tr>
            {% endif %}
            <tr><th>Avg Official Rank</th><td>{{ match_intelligence.next_match.opponent_average_official_rank if match_intelligence.next_match.opponent_average_official_rank is not none else "N/A" }}</td></tr>
            <tr><th>Avg Power Rank</th><td>{{ match_intelligence.next_match.opponent_average_power_rank if match_intelligence.next_match.opponent_average_power_rank is not none else "N/A" }}</td></tr>
          </tbody>
        </table>
        {% if match_intelligence.next_match.opponent_rows %}
          <table style="margin-top: 12px;">
            <thead>
              <tr><th>Team</th><th>Official</th><th>Power</th><th>Record</th><th>Skills</th><th>OPR</th></tr>
            </thead>
            <tbody>
              {% for item in match_intelligence.next_match.opponent_rows %}
                <tr>
                  <td>{{ item.team_number }}</td>
                  <td>{{ item.official_rank if item.official_rank is not none else "N/A" }}</td>
                  <td>{{ item.power_rank if item.power_rank is not none else "N/A" }}</td>
                  <td>{{ item.record_text or "Unknown" }}</td>
                  <td>{{ item.skills_total if item.skills_total is not none else "N/A" }}</td>
                  <td>{{ item.opr if item.opr is not none else "N/A" }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        {% endif %}
      {% else %}
        <div class="muted-panel">No scheduled focal-team match is stored yet.</div>
      {% endif %}
    </section>

    <section class="summary-card">
      {{ ui.section_header("Scout", "Last Match Context", "Most recent completed match with opponent context.") }}
      {% if match_intelligence.last_match %}
        <table>
          <tbody>
            <tr><th>Match</th><td>{{ match_intelligence.last_match.round_label or match_intelligence.last_match.match_key }}</td></tr>
            <tr><th>Opponents</th><td>{{ ", ".join(match_intelligence.last_match.opponent_teams) if match_intelligence.last_match.opponent_teams else match_intelligence.last_match.opponent or "TBD" }}</td></tr>
            <tr><th>Score</th><td>{{ match_intelligence.last_match.score_for or "?" }}-{{ match_intelligence.last_match.score_against or "?" }}</td></tr>
            <tr><th>Completed</th><td>{{ match_intelligence.last_match.completed_time or "Unknown" }}</td></tr>
            <tr><th>Avg Official Rank</th><td>{{ match_intelligence.last_match.opponent_average_official_rank if match_intelligence.last_match.opponent_average_official_rank is not none else "N/A" }}</td></tr>
            <tr><th>Avg Power Rank</th><td>{{ match_intelligence.last_match.opponent_average_power_rank if match_intelligence.last_match.opponent_average_power_rank is not none else "N/A" }}</td></tr>
          </tbody>
        </table>
      {% else %}
        <div class="muted-panel">No completed focal-team match is stored yet.</div>
      {% endif %}
    </section>
  </div>

  <section class="summary-card" style="margin-top: 16px;">
    {{ ui.section_header("Slate", "Ranked Upcoming Matchups", "The next known matchups with partner and opponent ranking context across the slate.") }}
    {% if matchup_summary %}
      <div class="muted-panel" style="margin-bottom: 12px;">{{ matchup_summary.headline }}</div>
    {% endif %}
    {% if upcoming_matchups %}
      <table>
        <thead>
          <tr><th>Match</th><th>Time</th><th>Location</th><th>Alliance</th><th>Partners</th><th>Opponents</th><th>Partner Avg</th><th>Opponent Avg</th><th>Source</th><th>Call</th></tr>
        </thead>
        <tbody>
          {% for item in upcoming_matchups[:(6 if static_site else upcoming_matchups|length)] %}
            <tr>
              <td>{{ item.round_label or item.match_key }}</td>
              <td>{{ display_time(item.scheduled_time) if static_site and item.scheduled_time else item.scheduled_time or "TBD" }}</td>
              <td>{{ item.field_name or "TBD" }}</td>
              <td>{{ item.alliance or "N/A" }}</td>
              <td>{{ ", ".join(item.partner_teams) if item.partner_teams else "TBD" }}</td>
              <td>{{ ", ".join(item.opponent_teams) if item.opponent_teams else item.opponent or "TBD" }}</td>
              <td>#{{ item.partner_average_official_rank if item.partner_average_official_rank is not none else "N/A" }} / P#{{ item.partner_average_power_rank if item.partner_average_power_rank is not none else "N/A" }}</td>
              <td>#{{ item.opponent_average_official_rank if item.opponent_average_official_rank is not none else "N/A" }} / P#{{ item.opponent_average_power_rank if item.opponent_average_power_rank is not none else "N/A" }}</td>
              <td>{% if static_site %}{{ display_source_name(item.source) }}{% else %}{% set source_class = "source-" ~ (item.source or "unknown")|replace("_", "-") %}<span class="badge {{ source_class }}">{{ (item.source or "unknown")|replace("_", " ") }}</span>{% endif %}</td>
              <td>{{ item.matchup_call }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <div class="muted-panel">No upcoming {{ team_label }} matchup slate is available from the local cache yet. VEX Via may be showing newer in-memory data than the local SQLite cache.</div>
    {% endif %}
  </section>

  <div class="split">
    <section class="summary-card">
      {{ ui.section_header("Swing", "Swing Matches", "Upcoming matches most likely to move the selected team’s trajectory based on opponent closeness and scoring pressure.") }}
      {% if swing_matches %}
        <table>
          <thead>
            <tr><th>Match</th><th>Opponents</th><th>Scheduled</th><th>Avg Official</th><th>Avg Power</th><th>Swing</th></tr>
          </thead>
          <tbody>
            {% for item in swing_matches[:(5 if static_site else swing_matches|length)] %}
              <tr>
                <td>{{ item.round_label or item.match_key }}</td>
                <td>{{ ", ".join(item.opponent_teams) if item.opponent_teams else item.opponent or "TBD" }}</td>
                <td>{{ display_time(item.scheduled_time) if static_site and item.scheduled_time else item.scheduled_time or "TBD" }}</td>
                <td>{{ item.opponent_average_official_rank if item.opponent_average_official_rank is not none else "N/A" }}</td>
                <td>{{ item.opponent_average_power_rank if item.opponent_average_power_rank is not none else "N/A" }}</td>
                <td>{{ item.swing_score }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <div class="muted-panel">No swing-match candidates yet.</div>
      {% endif %}
    </section>
  </div>

  {% if not static_site %}
  <div class="split">
    <section class="summary-card">
      {{ ui.section_header("Alliance", "Partner Impact", "Which partners have coincided with the strongest observed margins for the selected team so far.") }}
      {% if alliance_impact.partner_rows %}
        <table>
          <thead>
            <tr><th>Partner</th><th>Matches</th><th>Avg Margin</th><th>Official</th><th>Power</th><th>Skills</th></tr>
          </thead>
          <tbody>
            {% for item in alliance_impact.partner_rows %}
              <tr>
                <td>{{ item.team_number }}</td>
                <td>{{ item.matches }}</td>
                <td>{{ item.average_margin }}</td>
                <td>{{ item.official_rank if item.official_rank is not none else "N/A" }}</td>
                <td>{{ item.power_rank if item.power_rank is not none else "N/A" }}</td>
                <td>{{ item.skills_total if item.skills_total is not none else "N/A" }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <div class="muted-panel">No partner-impact data yet.</div>
      {% endif %}
    </section>

    <section class="summary-card">
      {{ ui.section_header("Alliance", "Opponent Pressure", "Opponents associated with the roughest observed margins against the selected team.") }}
      {% if alliance_impact.opponent_rows %}
        <table>
          <thead>
            <tr><th>Opponent</th><th>Matches</th><th>Avg Margin</th><th>Official</th><th>Power</th><th>OPR</th></tr>
          </thead>
          <tbody>
            {% for item in alliance_impact.opponent_rows %}
              <tr>
                <td>{{ item.team_number }}</td>
                <td>{{ item.matches }}</td>
                <td>{{ item.average_margin }}</td>
                <td>{{ item.official_rank if item.official_rank is not none else "N/A" }}</td>
                <td>{{ item.power_rank if item.power_rank is not none else "N/A" }}</td>
                <td>{{ item.opr if item.opr is not none else "N/A" }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <div class="muted-panel">No opponent-pressure data yet.</div>
      {% endif %}
    </section>
  </div>

  <div class="split">
    <section class="summary-card">
      {{ ui.section_header("Completed", "Recent Results", "Latest completed matches stored in SQLite.") }}
      {% if recent_completed_matches %}
        <table>
          <thead>
            <tr><th>Match</th><th>Alliance</th><th>Opponent</th><th>Score</th><th>Completed</th></tr>
          </thead>
          <tbody>
            {% for match in recent_completed_matches %}
              <tr>
                <td>{{ match.round_label }}</td>
                <td>{{ match.alliance or "N/A" }}</td>
                <td>{{ match.opponent }}</td>
                <td>{{ match.score_for or "?" }}-{{ match.score_against or "?" }}</td>
                <td>{{ match.completed_time or "Unknown" }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <div class="muted-panel">No completed matches yet.</div>
      {% endif %}
    </section>

    <section class="summary-card">
      {{ ui.section_header("Upcoming", "Scheduled Matches", "Future match slots currently known to the collector.") }}
      {% if upcoming_matches %}
        <table>
          <thead>
            <tr><th>Match</th><th>Opponent</th><th>Scheduled</th><th>Status</th></tr>
          </thead>
          <tbody>
            {% for match in upcoming_matches %}
              <tr>
                <td>{{ match.round_label }}</td>
                <td>{{ match.opponent }}</td>
                <td>{{ match.scheduled_time or "TBD" }}</td>
                <td>{{ match.status }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <div class="muted-panel">No upcoming matches yet.</div>
      {% endif %}
    </section>
  </div>
  {% endif %}
{% endblock %}
