<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title or "VEX Monitor GUI" }}</title>
    <style>
      :root {
        --bg: #081018;
        --panel: rgba(14, 24, 36, 0.9);
        --panel-strong: #121d2a;
        --ink: #ecf3fb;
        --muted: #96a8bc;
        --border: rgba(124, 157, 189, 0.18);
        --accent-green: #58cc79;
        --accent-2: #68d996;
        --warning: #f3b454;
        --danger: #ff7b72;
        --success: #4ed39a;
        --shadow: 0 20px 48px rgba(2, 8, 18, 0.45);
        --radius-lg: 24px;
        --radius-md: 18px;
        --radius-sm: 12px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Inter", "Avenir Next", "Segoe UI", sans-serif;
        color: var(--ink);
        line-height: 1.55;
        background:
          radial-gradient(circle at top left, rgba(57, 160, 255, 0.16), transparent 30%),
          radial-gradient(circle at top right, rgba(105, 240, 143, 0.1), transparent 24%),
          linear-gradient(rgba(105, 240, 143, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(105, 240, 143, 0.025) 1px, transparent 1px),
          linear-gradient(180deg, #07101a 0%, var(--bg) 100%);
        background-size: auto, auto, 28px 28px, 28px 28px, auto;
      }
      a { color: var(--accent-2); text-decoration: none; }
      a:hover { color: var(--ink); }
      .page { max-width: 1480px; margin: 0 auto; padding: 22px; }
      .top-shell { display: grid; gap: 18px; }
      .app-header, .content-shell {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }
      .app-header { padding: 20px 22px 18px; }
      .content-shell { padding: 24px; }
      .header-row, .page-intro {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: flex-start;
        flex-wrap: wrap;
      }
      .brand h1 { margin: 0; font-size: 2.2rem; letter-spacing: -0.04em; font-weight: 760; }
      .brand p, .small { color: var(--muted); line-height: 1.6; }
      .selected-meta, .btn-row, .header-tools, .tab-bar { display: flex; flex-wrap: wrap; gap: 10px; }
      .chip, .badge {
        display: inline-block;
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.09), rgba(105, 240, 143, 0.08));
      }
      .badge-threat-critical { color: #ff9b9b; border-color: rgba(255, 123, 114, 0.45); background: rgba(255, 123, 114, 0.14); }
      .badge-threat-high { color: #ffcc8a; border-color: rgba(243, 180, 84, 0.4); background: rgba(243, 180, 84, 0.14); }
      .badge-threat-moderate { color: #d9f59b; border-color: rgba(88, 204, 121, 0.35); background: rgba(88, 204, 121, 0.12); }
      .badge-threat-watch { color: #96a8bc; }
      .badge-risk-high { color: #ff9b9b; border-color: rgba(255, 123, 114, 0.45); background: rgba(255, 123, 114, 0.14); }
      .badge-risk-moderate { color: #ffcc8a; border-color: rgba(243, 180, 84, 0.4); background: rgba(243, 180, 84, 0.14); }
      .badge-risk-low { color: #d9f59b; border-color: rgba(88, 204, 121, 0.35); background: rgba(88, 204, 121, 0.12); }
      .badge.official { color: var(--success); }
      .badge.trusted { color: var(--warning); }
      .badge.unverified { color: #d7c2ff; }
      .badge.social { color: #ffd77d; }
      .badge.source-vex-via-local { color: #9ed0ff; border-color: rgba(87, 160, 255, 0.35); background: rgba(87, 160, 255, 0.12); }
      .badge.source-observed-vex-via { color: #ffd77d; border-color: rgba(243, 180, 84, 0.35); background: rgba(243, 180, 84, 0.14); }
      .badge.source-unknown { color: var(--muted); }
      .badge.health-healthy { color: var(--success); border-color: rgba(78, 211, 154, 0.35); background: rgba(78, 211, 154, 0.12); }
      .badge.health-degraded { color: var(--warning); border-color: rgba(243, 180, 84, 0.35); background: rgba(243, 180, 84, 0.12); }
      .badge.health-failed { color: var(--danger); border-color: rgba(255, 123, 114, 0.4); background: rgba(255, 123, 114, 0.14); }
      .badge.health-restart-requested { color: #ffd77d; border-color: rgba(243, 180, 84, 0.35); background: rgba(243, 180, 84, 0.14); }
      .badge.health-unknown { color: var(--muted); }
      .section-label {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.12), rgba(105, 240, 143, 0.12));
        color: var(--accent-green);
        font-size: 0.74rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
        font-weight: 700;
      }
      .header-action, button.header-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: linear-gradient(180deg, rgba(20, 31, 45, 0.95), rgba(14, 24, 36, 0.95));
        color: var(--ink);
        text-decoration: none;
        white-space: nowrap;
        cursor: pointer;
      }
      .tab-bar a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 112px;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        color: var(--muted);
        border: 1px solid var(--border);
        background: rgba(18, 29, 42, 0.75);
      }
      .tab-bar a.active {
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.22), rgba(105, 240, 143, 0.14));
        color: var(--ink);
        border-color: rgba(105, 240, 143, 0.35);
      }
      .panel {
        background: var(--panel-strong);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 18px;
        box-shadow: 0 12px 30px rgba(2, 8, 18, 0.28);
      }
      .page-intro-copy { max-width: 760px; }
      .page-intro-title, .surface-title { margin: 0; letter-spacing: -0.04em; }
      .page-intro-title { font-size: 1.56rem; line-height: 1.08; font-weight: 760; }
      .page-intro-subtitle, .surface-subtitle { margin: 8px 0 0; color: var(--muted); }
      .surface-header { display: grid; gap: 4px; margin-bottom: 12px; }
      .page-metric-grid, .grid, .split, .triple {
        display: grid;
        gap: 14px;
      }
      .page-metric-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
      .grid { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
      .split { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .triple { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .metric {
        padding: 18px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.12), rgba(105, 240, 143, 0.1));
        border: 1px solid rgba(105, 240, 143, 0.12);
        min-width: 0;
      }
      .metric strong {
        display: block;
        margin-top: 6px;
        font-weight: 760;
        min-width: 0;
      }
      .metric-value {
        font-size: clamp(1.45rem, 2.4vw, 2.75rem);
        line-height: 1.08;
        letter-spacing: -0.05em;
        overflow-wrap: anywhere;
        word-break: break-word;
        text-wrap: balance;
      }
      .metric-value-compact {
        font-size: clamp(1.05rem, 1.7vw, 1.95rem);
        line-height: 1.2;
        letter-spacing: -0.03em;
      }
      .metric-value-data {
        font-family: "SFMono-Regular", "Menlo", "Monaco", monospace;
        font-size: clamp(0.95rem, 1.45vw, 1.45rem);
        line-height: 1.35;
        letter-spacing: -0.01em;
        text-wrap: pretty;
      }
      .surface-stack { display: grid; gap: 18px; }
      .summary-card {
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, rgba(18, 29, 42, 0.96), rgba(14, 23, 34, 0.96));
        padding: 18px;
      }
      .list-table, table { width: 100%; border-collapse: collapse; }
      th, td {
        text-align: left;
        padding: 10px 8px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }
      th {
        color: var(--muted);
        font-size: 0.83rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 600;
      }
      th a.sort-link {
        color: inherit;
        text-decoration: none;
      }
      th a.sort-link:hover { color: var(--ink); }
      .muted-panel {
        padding: 14px;
        border-radius: 14px;
        border: 1px dashed var(--border);
        background: rgba(7, 14, 22, 0.62);
        color: var(--muted);
      }
      textarea, input[type="text"] {
        width: 100%;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: rgba(7, 14, 22, 0.82);
        color: var(--ink);
        font: inherit;
      }
      textarea { min-height: 180px; resize: vertical; }
      .form-stack { display: grid; gap: 12px; }
      .flash {
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(88, 204, 121, 0.3);
        background: rgba(88, 204, 121, 0.12);
      }
      .flash.warning {
        border-color: rgba(243, 180, 84, 0.35);
        background: rgba(243, 180, 84, 0.12);
      }
      .flash.danger {
        border-color: rgba(255, 123, 114, 0.35);
        background: rgba(255, 123, 114, 0.12);
      }
      .mono { font-family: "SFMono-Regular", "Menlo", monospace; }
      .scroll-table { overflow-x: auto; }
      .page-note { margin-top: 10px; color: var(--muted); }
      @media (max-width: 1100px) {
        .page-metric-grid, .split, .triple { grid-template-columns: 1fr; }
      }
      @media (max-width: 1400px) {
        .page-metric-grid {
          grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="top-shell">
        <header class="app-header">
          <div class="header-row">
            <div class="brand">
              <span class="section-label">VEX Worlds 2026</span>
              <h1>{% if static_site %}Team {{ settings.team_number }} Snapshot Dashboard{% else %}Team {{ settings.team_number }} Monitoring Console{% endif %}</h1>
              <p>{{ settings.team_name_alias }} · {{ settings.school_alias }}</p>
              {% if static_site and export_metadata %}
                <div class="page-note small">
                  Published {{ export_metadata.generated_at }} · Source {{ export_metadata.source_type or "unknown" }} · Snapshot {{ export_metadata.source_snapshot_at or "unknown" }}
                </div>
              {% endif %}
            </div>
            <div class="header-tools">
              <div class="chip">{{ status_banner.headline }}</div>
              <div class="chip">{{ status_banner.subtext }}</div>
              {% if dashboard_health %}
                <div class="badge health-{{ dashboard_health.status or 'unknown' }}">Automation {{ (dashboard_health.status or "unknown")|title }}</div>
              {% endif %}
              {% if media_state and not static_site %}
                <div class="chip">Media Watcher {{ media_state.status|title if media_state.status else "Idle" }}</div>
              {% endif %}
              {% if static_site %}
                <span class="chip">Static Snapshot</span>
              {% else %}
                <form method="post" action="/actions/run-now">
                  <button type="submit" class="header-action">Run Refresh</button>
                </form>
              {% endif %}
            </div>
          </div>
          <div class="selected-meta small">
            <span class="chip">Event {{ settings.event_sku }}</span>
            <span class="chip">Division {{ settings.division_name }}</span>
            <span class="chip">Competition {{ settings.poll_interval_minutes }}m</span>
            {% if not static_site %}
              <span class="chip">Media {{ settings.media_interval_minutes }}m</span>
              <span class="chip">Refresh Manual + Launch</span>
            {% else %}
              <span class="chip">Static Export Hourly</span>
              <span class="chip">Public GitHub Pages</span>
            {% endif %}
            <span class="chip">Optional Social {{ "On" if settings.enable_optional_social else "Off" }}</span>
          </div>
          <nav class="tab-bar">
            {% for key, href, label in nav_items %}
              <a href="{{ href }}" class="{% if active_tab == key %}active{% endif %}">{{ label }}</a>
            {% endfor %}
          </nav>
        </header>
        <main class="content-shell">
          {% if action_message %}
            <div class="flash">{{ action_message.replace("+", " ") }}</div>
          {% endif %}
          {% if refresh_state and refresh_state.message and not static_site %}
            <div class="flash{% if refresh_state.status == 'failed' %} danger{% elif refresh_state.status in ('queued', 'running') %} warning{% endif %}">
              {{ refresh_state.message }}
            </div>
          {% endif %}
          {% block content %}{% endblock %}
        </main>
      </div>
    </div>
  </body>
</html>
