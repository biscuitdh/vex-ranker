<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title or "VEX Monitor GUI" }}</title>
    <style>
      :root {
        --bg: #081018;
        --panel: rgba(14, 24, 36, 0.9);
        --panel-strong: #121d2a;
        --ink: #ecf3fb;
        --muted: #96a8bc;
        --border: rgba(124, 157, 189, 0.18);
        --accent-green: #58cc79;
        --accent-2: #68d996;
        --warning: #f3b454;
        --danger: #ff7b72;
        --success: #4ed39a;
        --shadow: 0 20px 48px rgba(2, 8, 18, 0.45);
        --radius-lg: 24px;
        --radius-md: 18px;
        --radius-sm: 12px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Inter", "Avenir Next", "Segoe UI", sans-serif;
        color: var(--ink);
        line-height: 1.55;
        background:
          radial-gradient(circle at top left, rgba(57, 160, 255, 0.16), transparent 30%),
          radial-gradient(circle at top right, rgba(105, 240, 143, 0.1), transparent 24%),
          linear-gradient(rgba(105, 240, 143, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(105, 240, 143, 0.025) 1px, transparent 1px),
          linear-gradient(180deg, #07101a 0%, var(--bg) 100%);
        background-size: auto, auto, 28px 28px, 28px 28px, auto;
      }
      a { color: var(--accent-2); text-decoration: none; }
      a:hover { color: var(--ink); }
      .page { max-width: 1480px; margin: 0 auto; padding: 22px; }
      body.public-shell .page { max-width: 980px; }
      .top-shell { display: grid; gap: 18px; }
      .app-header, .content-shell {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }
      .app-header { padding: 20px 22px 18px; }
      .content-shell { padding: 24px; }
      .header-row, .page-intro {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: flex-start;
        flex-wrap: wrap;
      }
      .brand h1 { margin: 0; font-size: 2.2rem; letter-spacing: -0.04em; font-weight: 760; }
      .brand p, .small { color: var(--muted); line-height: 1.6; }
      .selected-meta, .btn-row, .header-tools, .tab-bar { display: flex; flex-wrap: wrap; gap: 10px; }
      .team-picker {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        margin-top: 12px;
      }
      .team-picker input[type="text"] {
        min-width: 180px;
        max-width: 260px;
      }
      .chip, .badge {
        display: inline-block;
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.09), rgba(105, 240, 143, 0.08));
      }
      .badge-threat-critical { color: #ff9b9b; border-color: rgba(255, 123, 114, 0.45); background: rgba(255, 123, 114, 0.14); }
      .badge-threat-high { color: #ffcc8a; border-color: rgba(243, 180, 84, 0.4); background: rgba(243, 180, 84, 0.14); }
      .badge-threat-moderate { color: #d9f59b; border-color: rgba(88, 204, 121, 0.35); background: rgba(88, 204, 121, 0.12); }
      .badge-threat-watch { color: #96a8bc; }
      .badge-risk-high { color: #ff9b9b; border-color: rgba(255, 123, 114, 0.45); background: rgba(255, 123, 114, 0.14); }
      .badge-risk-moderate { color: #ffcc8a; border-color: rgba(243, 180, 84, 0.4); background: rgba(243, 180, 84, 0.14); }
      .badge-risk-low { color: #d9f59b; border-color: rgba(88, 204, 121, 0.35); background: rgba(88, 204, 121, 0.12); }
      .badge.official { color: var(--success); }
      .badge.trusted { color: var(--warning); }
      .badge.unverified { color: #d7c2ff; }
      .badge.social { color: #ffd77d; }
      .badge.source-vex-via-local { color: #9ed0ff; border-color: rgba(87, 160, 255, 0.35); background: rgba(87, 160, 255, 0.12); }
      .badge.source-observed-vex-via { color: #ffd77d; border-color: rgba(243, 180, 84, 0.35); background: rgba(243, 180, 84, 0.14); }
      .badge.source-unknown { color: var(--muted); }
      .badge.health-healthy { color: var(--success); border-color: rgba(78, 211, 154, 0.35); background: rgba(78, 211, 154, 0.12); }
      .badge.health-degraded { color: var(--warning); border-color: rgba(243, 180, 84, 0.35); background: rgba(243, 180, 84, 0.12); }
      .badge.health-failed { color: var(--danger); border-color: rgba(255, 123, 114, 0.4); background: rgba(255, 123, 114, 0.14); }
      .badge.health-restart-requested { color: #ffd77d; border-color: rgba(243, 180, 84, 0.35); background: rgba(243, 180, 84, 0.14); }
      .badge.health-unknown { color: var(--muted); }
      .section-label {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.12), rgba(105, 240, 143, 0.12));
        color: var(--accent-green);
        font-size: 0.74rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
        font-weight: 700;
      }
      .header-action, button.header-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: linear-gradient(180deg, rgba(20, 31, 45, 0.95), rgba(14, 24, 36, 0.95));
        color: var(--ink);
        text-decoration: none;
        white-space: nowrap;
        cursor: pointer;
      }
      .tab-bar a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 112px;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        color: var(--muted);
        border: 1px solid var(--border);
        background: rgba(18, 29, 42, 0.75);
      }
      .tab-bar a.active {
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.22), rgba(105, 240, 143, 0.14));
        color: var(--ink);
        border-color: rgba(105, 240, 143, 0.35);
      }
      .panel {
        background: var(--panel-strong);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 18px;
        box-shadow: 0 12px 30px rgba(2, 8, 18, 0.28);
      }
      .page-intro-copy { max-width: 760px; }
      .page-intro-title, .surface-title { margin: 0; letter-spacing: -0.04em; }
      .page-intro-title { font-size: 1.56rem; line-height: 1.08; font-weight: 760; }
      .page-intro-subtitle, .surface-subtitle { margin: 8px 0 0; color: var(--muted); }
      .surface-header { display: grid; gap: 4px; margin-bottom: 12px; }
      .page-metric-grid, .grid, .split, .triple {
        display: grid;
        gap: 14px;
      }
      .page-metric-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
      .grid { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
      .split { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .triple { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .metric {
        padding: 18px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(57, 160, 255, 0.12), rgba(105, 240, 143, 0.1));
        border: 1px solid rgba(105, 240, 143, 0.12);
        min-width: 0;
      }
      .metric strong {
        display: block;
        margin-top: 6px;
        font-weight: 760;
        min-width: 0;
      }
      .metric-value {
        font-size: clamp(1.45rem, 2.4vw, 2.75rem);
        line-height: 1.08;
        letter-spacing: -0.05em;
        overflow-wrap: anywhere;
        word-break: break-word;
        text-wrap: balance;
      }
      .metric-value-compact {
        font-size: clamp(1.05rem, 1.7vw, 1.95rem);
        line-height: 1.2;
        letter-spacing: -0.03em;
      }
      .metric-value-data {
        font-family: "SFMono-Regular", "Menlo", "Monaco", monospace;
        font-size: clamp(0.95rem, 1.45vw, 1.45rem);
        line-height: 1.35;
        letter-spacing: -0.01em;
        text-wrap: pretty;
      }
      .surface-stack { display: grid; gap: 18px; }
      .summary-card {
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, rgba(18, 29, 42, 0.96), rgba(14, 23, 34, 0.96));
        padding: 18px;
      }
      .list-table, table { width: 100%; border-collapse: collapse; }
      th, td {
        text-align: left;
        padding: 10px 8px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }
      th {
        color: var(--muted);
        font-size: 0.83rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 600;
      }
      th a.sort-link {
        color: inherit;
        text-decoration: none;
      }
      th a.sort-link:hover { color: var(--ink); }
      .muted-panel {
        padding: 14px;
        border-radius: 14px;
        border: 1px dashed var(--border);
        background: rgba(7, 14, 22, 0.62);
        color: var(--muted);
      }
      textarea, input[type="text"] {
        width: 100%;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: rgba(7, 14, 22, 0.82);
        color: var(--ink);
        font: inherit;
      }
      textarea { min-height: 180px; resize: vertical; }
      .form-stack { display: grid; gap: 12px; }
      .flash {
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(88, 204, 121, 0.3);
        background: rgba(88, 204, 121, 0.12);
      }
      .flash.warning {
        border-color: rgba(243, 180, 84, 0.35);
        background: rgba(243, 180, 84, 0.12);
      }
      .flash.danger {
        border-color: rgba(255, 123, 114, 0.35);
        background: rgba(255, 123, 114, 0.12);
      }
      .mono { font-family: "SFMono-Regular", "Menlo", monospace; }
      .scroll-table { overflow-x: auto; }
      .page-note { margin-top: 10px; color: var(--muted); }
      .public-nav {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .public-nav a {
        flex: 1 1 160px;
      }
      @media (max-width: 1100px) {
        .page-metric-grid, .split, .triple { grid-template-columns: 1fr; }
      }
      @media (max-width: 1400px) {
        .page-metric-grid {
          grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }
      }
      @media (max-width: 768px) {
        body.public-shell {
          background:
            radial-gradient(circle at top left, rgba(57, 160, 255, 0.18), transparent 32%),
            linear-gradient(180deg, #07101a 0%, var(--bg) 100%);
          background-size: auto, auto;
        }
        .page {
          padding: 12px;
        }
        .top-shell {
          gap: 12px;
        }
        .app-header {
          padding: 16px;
        }
        .content-shell,
        .panel,
        .summary-card,
        .metric {
          padding: 14px;
        }
        .brand h1 {
          font-size: 1.65rem;
        }
        .page-intro-title {
          font-size: 1.3rem;
        }
        .page-intro-subtitle,
        .surface-subtitle,
        .brand p,
        .small {
          font-size: 0.98rem;
          line-height: 1.5;
        }
        .page-metric-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 10px;
        }
        .metric-value {
          font-size: clamp(1.2rem, 7vw, 2rem);
        }
        .metric-value-compact,
        .metric-value-data {
          font-size: clamp(0.95rem, 4.2vw, 1.2rem);
        }
        .btn-row,
        .public-nav {
          width: 100%;
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 10px;
        }
        .header-action,
        button.header-action,
        .tab-bar a {
          width: 100%;
          min-width: 0;
          padding: 12px;
        }
        .tab-bar {
          display: grid;
          grid-template-columns: repeat(3, minmax(0, 1fr));
          gap: 8px;
        }
        table {
          display: block;
          overflow-x: auto;
          white-space: nowrap;
          -webkit-overflow-scrolling: touch;
        }
        th, td {
          padding: 9px 7px;
        }
      }
    </style>
  </head>
  {% set current_team = selected_team_number or settings.team_number %}
  {% set current_team_name = (latest_snapshot.team_name if latest_snapshot is defined and latest_snapshot and latest_snapshot.team_name else (selected_team_entry.team_name if selected_team_entry is defined and selected_team_entry and selected_team_entry.team_name else settings.team_name_alias)) %}
  {% set current_team_school = (latest_snapshot.school_name if latest_snapshot is defined and latest_snapshot and latest_snapshot.school_name else (selected_team_entry.organization if selected_team_entry is defined and selected_team_entry and selected_team_entry.organization else settings.school_alias)) %}
  <body class="{% if static_site %}public-shell{% else %}operator-shell{% endif %}" data-rendered-team="{{ rendered_team_number or current_team }}">
    <div class="page">
      <div class="top-shell">
        <header class="app-header">
          <div class="header-row">
            <div class="brand">
              <span class="section-label">VEX Worlds 2026</span>
              <h1>{% if static_site %}{{ current_team }} Match Day{% else %}Team {{ current_team }} Monitoring Console{% endif %}</h1>
              <p>{{ current_team_name }}{% if current_team_school %} · {{ current_team_school }}{% endif %}</p>
              {% if static_site and export_metadata %}
                <div class="page-note small">
                  Updated {{ display_time(export_metadata.generated_at) }}
                </div>
              {% endif %}
              {% if available_teams or static_team_manifest %}
                <form class="team-picker" method="get" action="{% if not static_site %}{{ current_path or '/' }}{% endif %}">
                  <input
                    type="text"
                    name="team"
                    list="team-options"
                    value="{{ current_team }}"
                    placeholder="Enter team number"
                    aria-label="Team number lookup"
                  >
                  <datalist id="team-options">
                    {% for item in (available_teams if available_teams else static_team_manifest) %}
                      <option value="{{ item.team_number }}">{{ item.team_name or item.organization or item.team_number }}</option>
                    {% endfor %}
                  </datalist>
                  <button type="submit" class="header-action">View Team</button>
                </form>
              {% endif %}
            </div>
            {% if not static_site %}
              <div class="header-tools">
                <div class="chip">{{ status_banner.headline }}</div>
                <div class="chip">{{ status_banner.subtext }}</div>
                {% if dashboard_health %}
                  <div class="badge health-{{ dashboard_health.status or 'unknown' }}">Automation {{ (dashboard_health.status or "unknown")|title }}</div>
                {% endif %}
                {% if media_state %}
                  <div class="chip">Media Watcher {{ media_state.status|title if media_state.status else "Idle" }}</div>
                {% endif %}
                <form method="post" action="/actions/run-now{% if team_query %}{{ team_query }}{% endif %}">
                  <button type="submit" class="header-action">Run Refresh</button>
                </form>
              </div>
            {% endif %}
          </div>
          {% if not static_site %}
            <div class="selected-meta small">
              <span class="chip">Event {{ settings.event_sku }}</span>
              <span class="chip">Division {{ settings.division_name }}</span>
              <span class="chip">Competition {{ settings.poll_interval_minutes }}m</span>
              <span class="chip">Media {{ settings.media_interval_minutes }}m</span>
              <span class="chip">Refresh Manual + {{ settings.poll_interval_minutes }}m</span>
              <span class="chip">Optional Social {{ "On" if settings.enable_optional_social else "Off" }}</span>
            </div>
          {% endif %}
          <nav class="tab-bar">
            {% for key, href, label in nav_items %}
              <a href="{{ href }}" class="{% if active_tab == key %}active{% endif %}">{{ label }}</a>
            {% endfor %}
          </nav>
        </header>
        <main class="content-shell">
          {% if action_message %}
            <div class="flash">{{ action_message.replace("+", " ") }}</div>
          {% endif %}
          {% if refresh_state and refresh_state.message and not static_site %}
            <div class="flash{% if refresh_state.status == 'failed' %} danger{% elif refresh_state.status in ('queued', 'running') %} warning{% endif %}">
              {{ refresh_state.message }}
            </div>
          {% endif %}
          {% block content %}{% endblock %}
        </main>
      </div>
    </div>
    {% if static_site and static_team_manifest %}
      <script>
        (() => {
          const formatLocalTimes = () => {
            for (const node of document.querySelectorAll(".local-time[data-iso]")) {
              const iso = node.dataset.iso;
              if (!iso) continue;
              const parsed = new Date(iso);
              if (Number.isNaN(parsed.getTime())) {
                if (node.dataset.fallback) node.textContent = node.dataset.fallback;
                continue;
              }
              node.textContent = new Intl.DateTimeFormat(undefined, {
                weekday: "short",
                month: "short",
                day: "numeric",
                hour: "numeric",
                minute: "2-digit",
              }).format(parsed).replace(",", " ·");
            }
          };
          formatLocalTimes();
          const requested = (new URLSearchParams(window.location.search).get("team") || "").trim().toUpperCase();
          const rendered = String(document.body.dataset.renderedTeam || "").trim().toUpperCase();
          if (!requested || requested === rendered) return;
          const manifest = {{ static_team_manifest|tojson }};
          const validTeams = new Set(manifest.map((item) => String(item.team_number || "").toUpperCase()));
          if (!validTeams.has(requested)) return;
          const pageKey = {{ active_tab|tojson }};
          const payloadBase = {{ team_payload_base|tojson }};
          fetch(`${payloadBase}/${requested}.json`, { credentials: "same-origin" })
            .then((response) => {
              if (!response.ok) {
                throw new Error(`team payload ${response.status}`);
              }
              return response.json();
            })
            .then((payload) => {
              const html = payload?.pages?.[pageKey];
              if (!html) {
                throw new Error("missing page html");
              }
              document.open();
              document.write(html);
              document.close();
            })
            .catch(() => {
              // Keep the default-team fallback if the requested payload is unavailable.
            });
        })();
      </script>
    {% endif %}
  </body>
</html>
