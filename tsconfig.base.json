{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@vex-ranker/db": ["packages/db/src/index.ts"],
      "@vex-ranker/ranking-engine": ["packages/ranking-engine/src/index.ts"],
      "@vex-ranker/vex-client": ["packages/vex-client/src/index.ts"],
      "@vex-ranker/collector": ["workers/collector/src/index.ts"]
    }
  }
}
