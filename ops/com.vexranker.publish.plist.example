<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.vexranker.publish</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/youruser/Documents/Projects/Vex Ranker/.venv/bin/python</string>
      <string>/Users/youruser/Documents/Projects/Vex Ranker/main.py</string>
      <string>--publish-static</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/youruser/Documents/Projects/Vex Ranker</string>

    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/youruser/Documents/Projects/Vex Ranker/logs/publish-static.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/youruser/Documents/Projects/Vex Ranker/logs/publish-static.err.log</string>
  </dict>
</plist>
